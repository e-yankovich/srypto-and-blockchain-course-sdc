      "project/contracts/Greeter.sol": {
        "content": "// SPDX-License-Identifier: MIT\npragma solidity ^0.8.28;\n\ncontract Greeter {\n    string private name;\n\n    constructor(string memory _name) {\n        name = _name;\n    }\n\n    function greet() public view returns (string memory) {\n        return string.concat(\"Hello, \", name, \"!\");\n    }\n}"
